# VeritasAI server environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# All variables are read at startup; restart the server after changing them.

# ---------------------------------------------------------------------------
# Required — the server will throw at startup without these
# ---------------------------------------------------------------------------

# Anthropic API key used to authenticate calls to Claude.
# Obtain one at https://console.anthropic.com/settings/api-keys
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-...

# Brave Search API key used by the fact-check pipeline to retrieve web results
# for each extracted claim. Obtain one at https://api.search.brave.com/
# A paid "Data for AI" subscription is required for programmatic access.
BRAVE_SEARCH_API_KEY=BSAv...

# ---------------------------------------------------------------------------
# CORS — controls which origins are allowed to call the API
# ---------------------------------------------------------------------------

# Comma-separated list of allowed request origins for CORS.
# Chrome extensions originate as chrome-extension://<extension-id>.
# Find your extension ID at chrome://extensions (enable Developer mode first).
# You can whitelist multiple origins by comma-separating them:
#   ALLOWED_ORIGINS=chrome-extension://abcdef123,https://mysite.example.com
# If this variable is empty or unset, all origins are allowed (open CORS).
# In production you should always restrict this to your specific extension ID.
ALLOWED_ORIGINS=chrome-extension://your-extension-id-here

# ---------------------------------------------------------------------------
# Server networking
# ---------------------------------------------------------------------------

# TCP port the Express server listens on.
# Defaults to 8787 if not set. Railway and other PaaS providers typically
# inject PORT automatically; set it explicitly for local development.
PORT=8787

# ---------------------------------------------------------------------------
# Share links
# ---------------------------------------------------------------------------

# Base URL prepended to /share/<id> when generating shareable links.
# Must include the scheme and host but no trailing slash.
# Examples:
#   Production:   PUBLIC_URL=https://veritasai-production-2477.up.railway.app
#   Local dev:    PUBLIC_URL=http://localhost:8787
# Defaults to http://localhost:<PORT> if not set.
PUBLIC_URL=https://your-deployed-domain.com
